{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vanish-box",
  "version": "0.1.0",
  "identifier": "com.vanishbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vanish Box",
        "width": 360,
        "height": 520,
        "minWidth": 300,
        "minHeight": 400,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
